# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
# A full AMQP URL wins when set. The scheduler runs on the broker host, but
# RabbitMQ binds to its external IP (not loopback), so RABBITMQ_HOST must be
# that IP — not localhost. Credentials are the shared AT9_USER / AT9_PASSWORD
# (the same ones the webservice uses — see webservice/src/modules/queue.js).
#
# Set RABBITMQ_URL only for a one-off / remote connection, e.g.
#   amqp://user:pass@queue.at9.app:5672/
# RABBITMQ_URL=

RABBITMQ_HOST=87.106.102.51
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/

# RabbitMQ credentials — shared with the webservice, injected from GitHub
# secrets by the deploy (never committed).
AT9_USER=
AT9_PASSWORD=

# Durable topic exchange + queue the webservice publishes booking events to
# (must match webservice/src/modules/queue.js). The scheduler binds the queue
# to `booking.#` — booking.created | booking.updated | booking.cancelled.
RABBITMQ_BOOKINGS_EXCHANGE=bookings
RABBITMQ_BOOKINGS_QUEUE=booking-messages

# ─── Postgres ─────────────────────────────────────────────────────────────────
# Booking events carry IDs only, so the scheduler reads customer + booking
# detail from the same database the webservice uses. Host/user/name are not
# secret; the password is injected from GitHub secrets by the deploy.
DB_HOST=db1.at9.app
DB_PORT=5432
DB_USER=postgres
DB_NAME=at9
DB_PASSWORD=

# ─── Brevo (email) ────────────────────────────────────────────────────────────
# Brevo transactional email over the SMTP relay. Host/port have safe defaults;
# the login and password are required.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=

# Default From: header. Override per-message by setting `from` in the
# payload. Format: `Display Name <address@domain>`.
EMAIL_FROM=At9 <noreply@at9.app>

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
