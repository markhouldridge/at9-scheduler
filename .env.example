# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
# Full AMQP URL. Locally the worker runs on the same host as RabbitMQ, so
# the default is the loopback. In other environments include credentials
# and host, e.g. amqp://user:pass@queue.at9.app:5672/
RABBITMQ_URL=amqp://localhost:5672

# Exchange producers publish to. Topic exchange — one exchange, many
# queues bound to different routing-key patterns.
RABBITMQ_EXCHANGE=at9.events

# ─── Resend ───────────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Default From: header. Override per-message by setting `from` in the
# payload. Format: `Display Name <address@domain>`.
EMAIL_FROM=At9 <noreply@at9.app>

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
