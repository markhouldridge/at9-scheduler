# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
# A full AMQP URL wins when set. On the broker host the scheduler runs on the
# same machine as RabbitMQ, so the discrete parts below reach it over localhost
# with the shared AT9_USER / AT9_PASSWORD credentials (the same ones the
# webservice uses — see webservice/src/modules/queue.js).
#
# Set RABBITMQ_URL only for a one-off / remote connection, e.g.
#   amqp://user:pass@queue.at9.app:5672/
# RABBITMQ_URL=

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/

# RabbitMQ credentials — shared with the webservice, injected from GitHub
# secrets by the deploy (never committed).
AT9_USER=
AT9_PASSWORD=

# Exchange producers publish to. Topic exchange — one exchange, many
# queues bound to different routing-key patterns.
RABBITMQ_EXCHANGE=at9.events

# ─── Brevo (email) ────────────────────────────────────────────────────────────
# Brevo transactional email over the SMTP relay. Host/port have safe defaults;
# the login and password are required.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=

# Default From: header. Override per-message by setting `from` in the
# payload. Format: `Display Name <address@domain>`.
EMAIL_FROM=At9 <noreply@at9.app>

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
